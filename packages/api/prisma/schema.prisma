generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String          @id @default(uuid())
  email          String          @unique
  password       String
  name           String?
  posts          Post[]
  tasks          Task[]
  projects       Project[]
  instagramToken InstagramToken?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

model Post {
  id          String      @id @default(uuid())
  caption     String?
  imageUrl    String?
  imageSource ImageSource @default(NANOBANA)
  nanoPrompt  String?
  status      PostStatus  @default(DRAFT)
  scheduledAt DateTime?
  publishedAt DateTime?
  instagramId String?
  source      PostSource  @default(WEB)
  hashtags    String[]
  aspectRatio String      @default("1:1")
  isCarousel  Boolean     @default(false)
  userId      String
  user        User        @relation(fields: [userId], references: [id])
  images      PostImage[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([status])
  @@index([scheduledAt])
  @@index([userId])
}

model PostImage {
  id        String      @id @default(uuid())
  imageUrl  String
  minioKey  String?
  order     Int         @default(0)
  source    ImageSource @default(NANOBANA)
  prompt    String?
  postId    String
  post      Post        @relation(fields: [postId], references: [id], onDelete: Cascade)
  createdAt DateTime    @default(now())

  @@index([postId])
  @@unique([postId, order])
}

model InstagramToken {
  id              String   @id @default(uuid())
  accessToken     String
  instagramUserId String
  pageId          String?
  expiresAt       DateTime
  refreshedAt     DateTime @default(now())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id])
}

enum PostStatus {
  DRAFT
  SCHEDULED
  PUBLISHING
  PUBLISHED
  FAILED
}

enum ImageSource {
  NANOBANA
  UPLOAD
  URL
}

enum PostSource {
  WEB
  TELEGRAM
  MCP
}

// === Task & Project enums ===

enum TaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TaskPlatform {
  YOUTUBE
  INSTAGRAM
  META_ADS
  TIKTOK
  OTHER
}

enum ProjectStatus {
  PLANNING
  IN_PROGRESS
  COMPLETED
  ARCHIVED
}

// === Task & Project models ===

model Task {
  id              String       @id @default(uuid())
  title           String
  description     String?
  platform        TaskPlatform @default(OTHER)
  status          TaskStatus   @default(PENDING)
  priority        TaskPriority @default(MEDIUM)
  recordDate      DateTime?
  publishDate     DateTime?
  script          String?
  driveLink       String?
  isSponsored     Boolean      @default(false)
  sponsorName     String?
  sponsorBriefing String?
  sponsorContact  String?
  sponsorDeadline DateTime?
  userId          String
  user            User         @relation(fields: [userId], references: [id])
  projectId       String?
  project         Project?     @relation(fields: [projectId], references: [id])
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([userId])
  @@index([status])
  @@index([priority])
  @@index([recordDate])
  @@index([publishDate])
  @@index([projectId])
}

model Project {
  id          String        @id @default(uuid())
  title       String
  description String?
  status      ProjectStatus @default(PLANNING)
  userId      String
  user        User          @relation(fields: [userId], references: [id])
  modules     ProjectModule[]
  tasks       Task[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([userId])
  @@index([status])
}

model ProjectModule {
  id         String   @id @default(uuid())
  title      String
  content    String?
  order      Int      @default(0)
  isRecorded Boolean  @default(false)
  driveLink  String?
  projectId  String
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([projectId])
  @@unique([projectId, order])
}
